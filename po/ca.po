#: setup/main.py:187
msgid "Preferences"
msgstr "Preferències"

#: setup/main.py:322
msgid "Restore all defaults"
msgstr "Restableix-ho tot al predeterminat"

#: setup/main.py:331 setup/main.py:7619 setup/pkginstall.py:254
